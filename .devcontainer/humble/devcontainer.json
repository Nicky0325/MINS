{
  "name": "MINS - ROS 2 Humble",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "../..",
    "args": {
      "USERNAME": "ros",
      "USER_UID": "1000",
      "USER_GID": "1000"
    }
  },
  "remoteUser": "ros",
  "containerEnv": {
    "ROS_DISTRO": "humble"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/src/MINS,type=bind",
  "workspaceFolder": "/workspaces/src/MINS",
  "postCreateCommand": "bash -lc 'source /opt/ros/humble/setup.bash && bash /workspaces/src/MINS/build_ros2.sh'",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-iot.vscode-ros",
        "ms-vscode.cpptools",
        "ms-python.python"
      ],
      "settings": {
        "python.analysis.extraPaths": [
          "/opt/ros/humble/lib/python3.10/site-packages"
        ],
        "python.autoComplete.extraPaths": [
          "/opt/ros/humble/lib/python3.10/site-packages"
        ]
      }
    }
  }
}
